QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: palette(base);
    margin: 0px;
    border: 1px solid palette(mid);
    border-radius: 2px;
    padding: 0px;
    height: {{ controls_height }};
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    background-color: palette(base);
    margin: 0px;
    border: 2px solid {{ palette('Selection') }};
    border-radius: 2px;
    padding: 0px;
}