HLine { background-color: palette(mid); }

Container {
    background-color: palette(base);
    border: 1px solid {{ palette('border') }};
    border-radius: 0.4ex;
}

/* --- Settings panel --- */

#SettingsPanel {
    background-color: palette(window);
}

#SettingsLeftPanel {
    background-color: palette(window);
}

#SettingsCategories {
    background-color: transparent;
    border: none;
    font-size: 1.3ex;
    outline: none;
}

#SettingsCategories::item {
    padding: 0.8ex 1.4ex;
    border-radius: 0.6ex;
    margin: 0.2ex 0.4ex;
}

#SettingsCategories::item:selected {
    background: {{ palette('Selection') }};
    color: palette(highlighted-text);
}

#SettingsCategories::item:hover:!selected {
    background: {{ palette('highlight') | alpha(30) }};
}

#SettingsCategoryHeader {
    color: palette(text);
}

#SettingsCategoryView {
    background-color: palette(window);
}

#SettingRow {
    background-color: palette(base);
    border: 1px solid {{ palette('border') }};
    border-radius: 0.6ex;
}

#SettingRow:hover {
    border-color: {{ palette('highlight') | alpha(100) }};
}

#SettingRow QLabel {
    background-color: transparent;
    border: none;
}

#SectionTitle {
    color: palette(text);
    background-color: transparent;
    border: none;
}

SciQLopPlotContainer[empty=false]{
    margin: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    padding: 0;
    border-image: none ;
}

SciQLopPlotContainer[empty=true] {
    margin: 0;
    border-top-width: 0;
    padding: 0;
    border-image: url(:/plot_panel_dd_background.png) 0 0 0 0 stretch stretch;
}

SciQLopPlotContainer::handle:vertical {
    height: 0.2ex;
    background: {{ palette('mid') }};
}

SciQLopPlotInterface{
    margin: 0;
    padding: 0;
}

CardsCollection {
    background-color: {{ palette('WelcomeBackground') }};
}

WelcomeSection {
    background-color: {{ palette('WelcomeBackground') }};
}

DetailedDescription {
    background-color: palette(base);
    border-left: 0.3ex solid {{ palette('Selection') }};
    border-radius: 0;
}

WelcomeSection QLabel {
    background-color: {{ palette('WelcomeBackground') }};
}

Card[selected=false] QLabel {
    background-color: palette(base);
    border: none;
}

Card[selected=true] QLabel {
    background-color: palette(base);
    border: none;
}

Card[selected=false] {
    background-color: palette(base);
    border: 1px solid {{ palette('border') }};
    border-radius: 0.6ex;
}

Card[selected=true] {
    border: 0.2ex solid palette(highlight);
    border-radius: 0.6ex;
}

Card:hover[selected=false] {
    border: 1px solid palette(highlight);
    border-radius: 0.6ex;
}

WorkSpaceCard[default_workspace=true] QLabel
{
    background-color: {{ palette('base') | darker(103)}};
    border: none;
}

WorkSpaceCard[default_workspace=true]
{
    background-color: {{ palette('base') | darker(103)}};
    border: 1px solid {{ palette('border') }};
    border-radius: 0.6ex;
}

ColorDelegate
{
    background-color: palette(Button);
    border: 1px solid {{ palette('border') }};
    border-radius: 0.4ex;
    height: 2.4ex;
}
